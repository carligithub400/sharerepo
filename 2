      {phase === 'climax' && (
        <div className="fixed inset-0 flex items-center justify-center z-30 bg-black/60 backdrop-blur-sm animate-fadeIn">
          <div className="text-center px-8">
            <div className="text-[120px] md:text-[180px] font-black animate-pulse leading-none" style={{ fontFamily: 'Orbitron, sans-serif' }}>
              <span className="bg-gradient-to-r from-amber-400 via-yellow-400 to-amber-500 bg-clip-text text-transparent">
                30
              </span>
            </div>
            <h2 className="text-3xl md:text-5xl font-bold text-white mb-6 tracking-wider mt-4">
              MACKAAY ICT SERVICES
            </h2>
            <div className="flex items-center justify-center gap-3 text-xl text-amber-400">
              <Building className="w-6 h-6" />
              <span>Nieuw Pand Aalsmeer</span>
            </div>
          </div>
        </div>
      )}

