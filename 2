              </svg>
            </div>

            <h1 className="text-4xl md:text-6xl font-black mb-2 tracking-wider text-white" style={{ fontFamily: 'Orbitron, sans-serif' }}>
              NIEUW PAND GEOPEND
            </h1>

            <p className="text-xl text-amber-400 mb-8">Lakenblekerstraat 21-A4, Aalsmeer</p>

            {/* Core values grid */}
            <div className="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10 max-w-3xl mx-auto">
              {zones.map(zone => (
                <div
                  key={zone.id}
                  className="p-5 rounded-xl border transition-all hover:scale-105"
                  style={{
                    background: 'rgba(4, 8, 20, 0.6)',
                    borderColor: `${zone.color}40`,
                  }}
                >
                  <div style={{ color: zone.color }} className="mb-2 flex justify-center">{zone.icon}</div>
                  <h3 className="text-sm font-bold tracking-wider text-white mb-1">{zone.label}</h3>
                  <p className="text-xs text-slate-500">{zone.sublabel}</p>
                </div>
              ))}
            </div>

            {/* Stats */}
            <div className="flex flex-wrap justify-center gap-8 mb-10">
              <div className="px-6 py-3 bg-white/5 rounded-lg border border-white/10">
                <div className="text-2xl font-bold text-amber-400">30+</div>
                <div className="text-xs text-slate-500 tracking-wider">JAAR ERVARING</div>
              </div>
              <div className="px-6 py-3 bg-white/5 rounded-lg border border-white/10">
                <div className="text-2xl font-bold text-cyan-400">500+</div>
                <div className="text-xs text-slate-500 tracking-wider">KLANTEN</div>
              </div>
              <div className="px-6 py-3 bg-white/5 rounded-lg border border-white/10">
                <div className="text-2xl font-bold text-green-400">ISO 27001</div>
                <div className="text-xs text-slate-500 tracking-wider">GECERTIFICEERD</div>
              </div>
            </div>

            {/* Reset button */}
            <button
              onClick={resetExperience}
              className="flex items-center gap-2 mx-auto px-6 py-3 rounded-xl border border-white/20 bg-white/5 text-white hover:bg-white/10 transition-all"
            >
              <RotateCcw className="w-4 h-4" />
              <span className="text-sm tracking-wider">Opnieuw starten</span>
            </button>
          </div>

          {/* Footer */}
          <div className="absolute bottom-8 left-0 right-0 text-center">
            <p className="text-slate-500 text-sm">
              www.mackaay.nl | Sinds 5 mei 1993
            </p>
          </div>
