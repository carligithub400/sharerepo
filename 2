                      style={{ width: `${ribbonCutProgress}%` }}
                    />
                  </div>
                </div>
              </div>
            )}
          </div>

          {/* Scissor cursor */}
          {phase === 'cutting' && isDragging && (
            <div
              className="fixed pointer-events-none z-50"
              style={{
                left: scissorPos.x,
                top: scissorPos.y,
                transform: 'translate(-50%, -50%) scale(-1, 1)'
              }}
            >
              <div className="relative">
                <Scissors className="w-12 h-12 text-amber-400 drop-shadow-lg" style={{ transform: `rotate(${ribbonCutProgress * 3.6}deg)` }} />
              </div>
            </div>
          )}

          {/* Bottom info */}
          <div className="absolute bottom-8 left-0 right-0 text-center">
            <div className="flex items-center justify-center gap-6 text-slate-500 text-sm">
              <span>Lakenblekerstraat 21-A4, Aalsmeer</span>
              <span className="text-amber-600">|</span>
              <span>Mei 2026</span>
            </div>
          </div>
        </div>
      )}

      {/* JOURNEY PHASE */}
      {phase === 'journey' && (
        <div className="fixed inset-0 flex items-center justify-center z-20 animate-fadeIn">
          <div className="text-center px-8">
            <div className="text-6xl md:text-8xl font-black mb-4" style={{ fontFamily: 'Orbitron, sans-serif' }}>
              <span
                className="bg-gradient-to-r from-amber-400 via-yellow-300 to-amber-500 bg-clip-text text-transparent"
                style={{ fontSize: `${60 + journeyProgress * 40}px` }}
              >
                {Math.floor(journeyProgress * 33) + 1993}
              </span>
            </div>
            <p className="text-xl text-slate-400 tracking-widest mb-8">JAAR MACKAAY</p>

            <div className="w-64 mx-auto mb-8">
              <div className="h-1 bg-slate-800 rounded-full overflow-hidden">
                <div
                  className="h-full bg-gradient-to-r from-red-500 via-cyan-500 to-amber-500"
                  style={{ width: `${journeyProgress * 100}%` }}
                />
              </div>
            </div>

            {/* Core values appearing */}
            <div className="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-2xl mx-auto">
              {zones.map((zone, i) => (
                <div
                  key={zone.id}
                  className="p-4 rounded-xl border transition-all opacity-0"
                  style={{
                    background: `rgba(4, 8, 20, 0.6)`,
                    borderColor: journeyProgress > (i + 1) * 0.25 ? zone.color : 'transparent',
                    opacity: journeyProgress > (i + 1) * 0.25 ? 1 : 0,
                    transition: 'all 0.5s ease',
                  }}
                >
                  <div style={{ color: zone.color }} className="mb-2 flex justify-center">{zone.icon}</div>
                  <h3 className="text-sm font-bold tracking-wider text-white">{zone.label}</h3>
                </div>
              ))}
            </div>
          </div>
        </div>
      )}

      {/* DECADE PHASES */}
      {phase.startsWith('decade') && currentDecadeData && (
        <div className="fixed inset-0 flex items-center justify-center z-20 animate-fadeIn">
          <div className="text-center px-8 max-w-3xl">
            <div
              className="text-7xl md:text-8xl font-black mb-10"
              style={{
                color: currentDecadeData.color,
                fontFamily: 'Orbitron, sans-serif',
                textShadow: `0 0 60px ${currentDecadeData.color}40`
              }}
            >
              {currentDecadeData.year}
            </div>

            <div className="space-y-5">
              {currentDecadeData.milestones.map((milestone, i) => (
                <div
                  key={i}
                  className="text-xl md:text-2xl text-slate-300 animate-slideUp"
                  style={{ animationDelay: `${i * 0.4}s` }}
                >
                  <ChevronRight className="inline w-6 h-6 mr-3" style={{ color: currentDecadeData.color }} />
                  {milestone}
                </div>
              ))}
            </div>

            {/* Progress dots */}
            <div className="mt-16 flex justify-center gap-3">
              {decades.map((decade, i) => (
                <div
                  key={i}
                  className={`w-3 h-3 rounded-full transition-all ${
                    phase === `decade${i + 1}` ? 'scale-150' : ''
                  }`}
                  style={{
                    background: phase === `decade${i + 1}` ? decade.color : 'rgba(255,255,255,0.2)',
                    boxShadow: phase === `decade${i + 1}` ? `0 0 20px ${decade.color}` : 'none'
                  }}
                />
              ))}
            </div>
          </div>
        </div>
      )}

